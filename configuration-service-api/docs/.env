# Server Configuration
PORT=4000
NODE_ENV=development

# MongoDB Configuration - SHARED DATABASE
MONGODB_URI=mongodb://localhost:27017/leadpylot

# JWT Configuration - MUST MATCH MONOLITH
JWT_

JWT_EXPIRES_IN=24h
SESSION_DURATION_HOURS=24

# Logging
LOG_LEVEL=info


# AWS Lightsail Object Storage (Frankfurt Region)
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=eu-central-1
AWS_S3_BUCKET=leadpylot
AWS_S3_ENDPOINT=https://s3.eu-central-1.amazonaws.com

# Storage Configuration
CLOUD_STORAGE_ENABLED=true
PREFERRED_STORAGE=cloud
STORAGE_FALLBACK_TO_LOCAL=true


# Microservices URLs (for inter-service communication)
USER_AUTH_SERVICE_URL=http://host.docker.internal:4000
DOCUMENT_SERVICE_URL=http://host.docker.internal:4002
CONFIGURATION_SERVICE_URL=http://host.docker.internal:4006

# Frontend Configuration
FRONTEND_URL=http://localhost:3001

# Storage Configuration
STORAGE_TYPE=local
STORAGE_PATH=/app/storage
TEMP_UPLOAD_PATH=/app/temp-uploads


# File Upload Limits
MAX_FILE_SIZE=52428800
MAX_FILES_PER_UPLOAD=20

# CORS Configuration
CORS_ORIGIN=http://localhost:3001


