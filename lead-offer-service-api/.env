# Lead Offers Service - Production Configuration
NODE_ENV=production
PORT=4003

# Database
# For local development with main project's database:
MONGODB_URI=mongodb://127.0.0.1:27017/uplead
# For remote production database:
# MONGODB_URI=mongodb://127.0.0.1:27017/uplead
authSource=admin

# Authentication - MUST match main project's JWT_SECRET
JWT_SECRET=26376907cc9db2245905e4b7beccd40aad896109f68beb822050ee0d845d2d17
# Cloud Storage
CLOUD_STORAGE_ENABLED=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
AWS_S3_BUCKET=leadpylot
AWS_S3_ENDPOINT=

# File Upl
# Service URLs (inter-service communication)
CONFIGURATION_SERVICE_URL==http://localhost:4006
USER_AUTH_SERVICE_URL=http://localhost:4000
DOCUMENT_SERVICE_URL=http://localhost:4002
EMAIL_SERVICE_URL=http://localhost:4008

# Frontend
FRONTEND_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3001

# Storage Configuration
STORAGE_TYPE=local
STORAGE_PATH=/path/to/storage
TEMP_UPLOAD_PATH=/path/to/temp-uploads

# AWS S3 Cloud Storage
CLOUD_STORAGE_ENABLED=true
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=leadpylot
AWS_S3_ENDPOINT=

# File Upl

# File Upload Limits
MAX_FILE_SIZE=52428800
MAX_FILES_PER_UPLOAD=20

# PDF Service
PDF_GENERATE_API_URL=http://localhost:4009/pdf/generate-offer

# Logging
LOG_LEVEL=info


CORS_ORIGIN=http://localhost:3001