# Lead & Offers Service - Environment Variables

# Server Configuration
NODE_ENV=development
PORT=4003

# Database Configuration
# Connect to SHARED MongoDB from main docker-compose
# For Docker: use host.docker.internal (macOS/Windows) or host.docker.internal (Linux)
# For local development: use localhost
MONGODB_URI=mongodb://host.docker.internal:27017/leadpylot

# Security
# IMPORTANT: Generate a strong JWT secret for production
# Example: openssl rand -base64 64
JWT_SECRET=your-secret-key-change-this-in-production

# Microservices URLs (for inter-service communication)
USER_AUTH_SERVICE_URL=http://host.docker.internal:4000
DOCUMENT_SERVICE_URL=http://host.docker.internal:4002
CONFIGURATION_SERVICE_URL=http://host.docker.internal:4006

# Frontend Configuration
FRONTEND_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3001

# Logging
# Levels: error, warn, info, http, debug
LOG_LEVEL=info

# Rate Limiting (optional)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=1000

# Lead AI Summary (OpenAI) - for activity-triggered summaries
# OPENAI_API_KEY=sk-...
# OPENAI_LEAD_SUMMARY_MODEL=gpt-4o-mini
# OPENAI_LEAD_SUMMARY_TIMEOUT=30000

# Leadbot Conversation API - for POST /leads/:id/generate-summary
# LEADBOT_CONVERSATION_URL=http://localhost:8000
# LEADBOT_CONVERSATION_TIMEOUT=30000
