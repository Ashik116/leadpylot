# ================================
# CRM 1 - Domain-specific production env
# Copy to .env.prod.crm1 and fill in values
# Build: npm run build:crm1
# ================================

AUTH_SECRET=your-crm1-secret
NEXTAUTH_URL=https://crm1.yourdomain.com
AUTH_TRUST_HOST=true

GOOGLE_AUTH_CLIENT_ID=***
GOOGLE_AUTH_CLIENT_SECRET=***
GITHUB_AUTH_CLIENT_ID=***
GITHUB_AUTH_CLIENT_SECRET=***

API_BASE_URL=https://crm1.yourdomain.com
NEXT_PUBLIC_API_BASE_URL=https://crm1.yourdomain.com

NEXT_PUBLIC_ONESIGNAL_APP_ID=***
NEXT_PUBLIC_INACTIVITY_ENABLED=false
NEXT_PUBLIC_SOCKET_PING_INTERVAL=60000
NEXT_PUBLIC_SOCKET_PING_TIMEOUT=30000
NEXT_PUBLIC_MONITORING_POLL_INTERVAL=15000
NEXT_PUBLIC_MONITORING_HEALTH_CHECK_INTERVAL=60000

# Microservices - same domain, nginx routes
NEXT_PUBLIC_USER_AUTH_SERVICE_URL=https://crm1.yourdomain.com
NEXT_PUBLIC_DOCUMENT_SERVICE_URL=https://crm1.yourdomain.com
NEXT_PUBLIC_LEAD_OFFERS_SERVICE_URL=https://crm1.yourdomain.com
NEXT_PUBLIC_NOTIFICATION_SERVICE_URL=https://crm1.yourdomain.com
NEXT_PUBLIC_CONFIG_SERVICE_URL=https://crm1.yourdomain.com
NEXT_PUBLIC_MAIL_SERVICE_URL=https://crm1.yourdomain.com
NEXT_PUBLIC_PDF_SERVICE_URL=https://crm1.yourdomain.com
NEXT_PUBLIC_REPORTING_SERVICE_URL=https://crm1.yourdomain.com
NEXT_PUBLIC_CALL_SERVICE_URL=https://crm1.yourdomain.com
NEXT_PUBLIC_SEARCH_SERVICE_URL=https://crm1.yourdomain.com
NEXT_PUBLIC_TODO_SERVICE_URL=https://crm1.yourdomain.com
NEXT_PUBLIC_USE_MICROSERVICES=true
NEXT_PUBLIC_MICROSERVICE_ROOT_API_URL=https://crm1.yourdomain.com
NEXT_PUBLIC_LEAD_BOT_SERVICE_URL=https://crm1.yourdomain.com
NEXT_PUBLIC_COMMUNICATION_SERVICE_URL=https://crm1.yourdomain.com

# Tenant
NEXT_PUBLIC_TENANT_ID=crm1
NEXT_PUBLIC_TENANT_NAME=CRM1
NEXT_PUBLIC_TENANT_TYPE=admin
NEXT_PUBLIC_TENANT_DOMAIN=crm1.yourdomain.com
NEXT_PUBLIC_TENANT_APP_NAME=CRM1
NEXT_PUBLIC_ALLOWED_ROLES=Admin,Manager,Agent,Banker
